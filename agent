import sys
import os
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

import asyncio
import json
import re
import time
import traceback
import websockets
import ollama

from utils import (
    SENSOR_HOST, SENSOR_PORT, SITE_HOST, SITE_PORT,
    NUM_BULBS, OLLAMA_MODEL,
    setup_logger, start_ollama_if_needed, ensure_model_available,
)

log = setup_logger("AGENT")


class SmartHomeAgent:

    SYSTEM_PROMPT = """Output JSON only. Schema:
{"states": [b,b,b,b,b], "brightness": "bright"}
b is true if lamp is on.
For N fingers: first N are true, rest false.
brightness is "bright" or "dim" (echo current mode).
No text. No markdown. Only JSON."""

    def __init__(self, model: str = OLLAMA_MODEL):
        self.model = model
        self.bulb_states = [False] * NUM_BULBS

        self.history = []
        self.dim_mode = False
        self.last_fingers = -1
        self.pattern_cooldown = 0

        self.llm_calls = 0
        self.cache_hits = 0
        self.pattern_detections = 0

        log.info(f"SmartHomeAgent создан, модель: {model}")

    def _build_user_prompt(self, fingers: int) -> str:
        mode = "DIM" if self.dim_mode else "BRIGHT"
        return f'fingers={fingers} mode={mode}'

    def _deterministic_decision(self, fingers: int) -> dict:
        n = max(0, min(int(fingers), NUM_BULBS))
        states = [True] * n + [False] * (NUM_BULBS - n)
        return {
            "states": states,
            "brightness": "dim" if self.dim_mode else "bright",
            "reasoning": f"fallback: {fingers} пальцев"
        }

    def detect_fist_to_palm(self, fingers: int) -> bool:
        if self.pattern_cooldown > 0:
            self.pattern_cooldown -= 1
            return False

        self.history.append(fingers)
        if len(self.history) > 4:
            self.history = self.history[-4:]

        if len(self.history) < 2:
            return False

        prev = self.history[-2]
        curr = self.history[-1]

        if (prev, curr) in [(0, 5), (5, 0)]:
            return True
        return False

    def update_dim_mode(self):
        if self.dim_mode:
            log.info("Режим DIM -> BRIGHT (ярко)")
            self.dim_mode = False
        else:
            log.info("Режим BRIGHT -> DIM (тускло)")
            self.dim_mode = True

        self.history = []
        self.pattern_cooldown = 3
        self.pattern_detections += 1

    def _parse_llm_response(self, content: str) -> dict | None:
        json_match = re.search(r'\{[^{}]*\}', content)
        parsed = None
        if json_match:
            try:
                parsed = json.loads(json_match.group(0))
            except Exception:
                parsed = None

        if parsed is None or not isinstance(parsed, dict):
            array_match = re.search(r'\[[^\[\]]*\]', content)
            if array_match:
                bools = re.findall(r'\b(true|false|1|0)\b', array_match.group(0), re.IGNORECASE)
                if len(bools) == NUM_BULBS:
                    return {
                        "states": [b.lower() in ("true", "1") for b in bools],
                        "brightness": "dim" if self.dim_mode else "bright",
                        "reasoning": "извлечено из текста"
                    }
            return None

        states_raw = parsed.get("states")
        if states_raw is None:
            return None

        if isinstance(states_raw, dict):
            states_raw = list(states_raw.values())

        if isinstance(states_raw, str):
            bools = re.findall(r'\b(true|false|1|0)\b', states_raw, re.IGNORECASE)
            if len(bools) != NUM_BULBS:
                return None
            states_raw = bools

        if not isinstance(states_raw, (list, tuple)) or len(states_raw) != NUM_BULBS:
            return None

        states = []
        for x in states_raw:
            if isinstance(x, bool):
                states.append(x)
            elif isinstance(x, (int, float)):
                states.append(bool(x))
            elif isinstance(x, str):
                states.append(x.lower() in ("true", "1", "yes"))
            else:
                states.append(False)

        brightness_raw = parsed.get("brightness", "").lower()
        if "dim" in brightness_raw or "тускло" in brightness_raw:
            brightness = "dim"
        else:
            brightness = "bright"

        return {
            "states": states,
            "brightness": brightness,
            "reasoning": parsed.get("reasoning", "")
        }

    async def ask_llm(self, fingers: int) -> dict:
        fallback = self._deterministic_decision(fingers)

        try:
            loop = asyncio.get_event_loop()

            def _call():
                return ollama.chat(
                    model=self.model,
                    messages=[
                        {"role": "system", "content": self.SYSTEM_PROMPT},
                        {"role": "user", "content": self._build_user_prompt(fingers)},
                    ],
                    format="json",
                    options={"temperature": 0},
                )

            start = time.time()
            response = await asyncio.wait_for(
                loop.run_in_executor(None, _call),
                timeout=10.0,
            )
            elapsed = time.time() - start

            content = response["message"]["content"].strip()
            log.debug(f"LLM ({elapsed:.2f}с) RAW: {content!r}")

            parsed = self._parse_llm_response(content)
            if parsed is None:
                log.warning(f"Парсинг не удался, fallback. RAW: {content!r}")
                return fallback

            n = max(0, min(int(fingers), NUM_BULBS))
            true_count = sum(parsed["states"])

            if true_count != n:
                log.warning(f"LLM: {true_count} true != {n} пальцев, исправляю")
                fallback_states = [True] * n + [False] * (NUM_BULBS - n)
                parsed["states"] = fallback_states

            return parsed

        except asyncio.TimeoutError:
            log.error("LLM timeout, fallback")
        except Exception as e:
            log.error(f"LLM error: {e}, fallback")

        return fallback

    async def decide(self, fingers: int) -> dict:
        if self.detect_fist_to_palm(fingers):
            self.update_dim_mode()
            decision = self._deterministic_decision(fingers)
            decision["reasoning"] = f"Кулак→Ладонь: {'тускло' if self.dim_mode else 'ярко'}"
            self.bulb_states = decision["states"]
            self.last_fingers = fingers
            return decision

        if fingers == self.last_fingers:
            self.cache_hits += 1
            return {
                "states": self.bulb_states,
                "brightness": "dim" if self.dim_mode else "bright",
                "reasoning": "кэш"
            }

        self.last_fingers = fingers
        self.llm_calls += 1

        decision = await self.ask_llm(fingers)
        self.bulb_states = decision["states"]
        log.info(f"Решение: {decision['reasoning']}")
        return decision

    def stats(self) -> str:
        return (f"LLM: {self.llm_calls}, кэш: {self.cache_hits}, "
                f"паттернов: {self.pattern_detections}, "
                f"режим: {'DIM' if self.dim_mode else 'BRIGHT'}")


agent: SmartHomeAgent | None = None


async def connect_to_sensor():
    while True:
        try:
            log.info(f"Подключаюсь к сенсору ws://{SENSOR_HOST}:{SENSOR_PORT}...")
            async with websockets.connect(
                f"ws://{SENSOR_HOST}:{SENSOR_PORT}",
                ping_interval=20,
                ping_timeout=10,
            ) as sensor_ws:
                log.info("Подключён к сенсору")

                while True:
                    data = await sensor_ws.recv()
                    payload = json.loads(data)
                    fingers = payload.get("fingers", 0)
                    hand = payload.get("hand_detected", False)

                    if not hand:
                        continue

                    if agent is None:
                        log.error("agent is None!")
                        continue

                    decision = await agent.decide(fingers)
                    log.info(f"Пальцев: {fingers} → {decision['states']} "
                             f"({decision['brightness']}) | {agent.stats()}")

        except (ConnectionRefusedError, OSError) as e:
            log.warning(f"Сенсор недоступен ({e}), повтор через 2с...")
            await asyncio.sleep(2)
        except websockets.ConnectionClosed:
            log.warning("Связь с сенсором потеряна, переподключаюсь...")
            await asyncio.sleep(1)
        except Exception as e:
            log.error(f"Ошибка в connect_to_sensor: {e}")
            log.error(traceback.format_exc())
            await asyncio.sleep(2)


async def site_handler(websocket):
    log.info(f"Сайт подключился: {websocket.remote_address}")
    try:
        while True:
            if agent is None:
                payload = {"states": [False] * NUM_BULBS, "brightness": "bright"}
            else:
                payload = {
                    "states": agent.bulb_states,
                    "brightness": "dim" if agent.dim_mode else "bright",
                    "reasoning": f"Режим: {'тускло' if agent.dim_mode else 'ярко'}",
                    "stats": agent.stats()
                }
            await websocket.send(json.dumps(payload))
            await asyncio.sleep(0.1)
    except websockets.ConnectionClosed:
        log.info("Сайт отключился")
    except Exception as e:
        log.error(f"Ошибка в site_handler: {e}")


async def main():
    global agent

    log.info("=" * 50)
    log.info("Запуск ИИ-агента умного дома")
    log.info("=" * 50)

    if not start_ollama_if_needed(log):
        log.error("Ollama не запущена, не могу работать")
        return

    if not ensure_model_available(OLLAMA_MODEL, log):
        log.warning(f"Модель {OLLAMA_MODEL} может быть недоступна")

    agent = SmartHomeAgent(model=OLLAMA_MODEL)

    sensor_task = asyncio.create_task(connect_to_sensor())
    log.info(f"Подключение к сенсору ws://{SENSOR_HOST}:{SENSOR_PORT}")

    log.info(f"Сервер для сайта: ws://{SITE_HOST}:{SITE_PORT}")
    log.info("Откройте site.html в браузере")

    async with websockets.serve(site_handler, SITE_HOST, SITE_PORT):
        try:
            await sensor_task
        except asyncio.CancelledError:
            log.info("Отмена задач")
        except Exception as e:
            log.error(f"Ошибка в main: {e}")
            log.error(traceback.format_exc())


if __name__ == "__main__":
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        log.info("Остановлено (Ctrl+C)")
    except Exception as e:
        log.error(f"Критическая ошибка: {e}")
        log.error(traceback.format_exc())
        input("Нажмите Enter для выхода...")
