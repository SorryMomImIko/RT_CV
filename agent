import sys
import os

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

import asyncio
import json
import re
import time
import traceback
import websockets
import ollama

from utils import (
    SENSOR_HOST, SENSOR_PORT, SITE_HOST, SITE_PORT,
    NUM_BULBS, OLLAMA_MODEL,
    setup_logger, start_ollama_if_needed, ensure_model_available,
)

log = setup_logger("AGENT")

SYSTEM_PROMPT = """Task: convert finger count to lamp array.

Rule: for N fingers, lamps[0..N-1] = true, lamps[N..4] = false.
Example: 3 fingers -> [true,true,true,false,false]
Example: 0 fingers -> [false,false,false,false,false]

Output JSON only, no text:
{"states":[b,b,b,b,b],"brightness":"bright"}"""


class SmartHomeAgent:

    def __init__(self, model: str = OLLAMA_MODEL):
        self.model = model
        self.bulb_states = [False] * NUM_BULBS
        self.history = []
        self.dim_mode = False
        self.last_fingers = -1
        self.llm_calls = 0
        self.cache_hits = 0
        self.gesture_detections = 0
        self.skipped_unstable = 0

        log.info(f"SmartHomeAgent создан, модель: {model}")

    def _deterministic_states(self, fingers: int) -> list:
        n = max(0, min(int(fingers), NUM_BULBS))
        return [True] * n + [False] * (NUM_BULBS - n)

    def _detect_gesture(self, fingers: int) -> bool:
        self.history.append(fingers)
        if len(self.history) > 6:
            self.history = self.history[-6:]

        if len(self.history) < 2:
            return False

        prev, curr = self.history[-2], self.history[-1]
        return (prev, curr) in [(0, 5), (5, 0)]

    def _parse_llm_response(self, content: str) -> dict | None:
        array_match = re.search(r'\[[^\[\]]*\]', content)
        if array_match:
            bools = re.findall(r'\b(true|false|1|0)\b', array_match.group(0), re.IGNORECASE)
            if len(bools) == NUM_BULBS:
                return {
                    "states": [b.lower() in ("true", "1") for b in bools],
                    "brightness": "dim" if self.dim_mode else "bright",
                }
        return None

    async def ask_llm(self, fingers: int) -> dict:
        n = max(0, min(int(fingers), NUM_BULBS))
        expected = [True] * n + [False] * (NUM_BULBS - n)

        for attempt in range(3):
            try:
                loop = asyncio.get_event_loop()

                def _call():
                    mode = "DIM" if self.dim_mode else "BRIGHT"
                    user_msg = f"fingers={fingers} mode={mode}"
                    return ollama.chat(
                        model=self.model,
                        messages=[
                            {"role": "system", "content": SYSTEM_PROMPT},
                            {"role": "user", "content": user_msg},
                        ],
                        format="json",
                        options={"temperature": 0},
                    )

                response = await asyncio.wait_for(
                    loop.run_in_executor(None, _call),
                    timeout=5.0,
                )

                content = response["message"]["content"].strip()
                log.debug(f"LLM attempt {attempt + 1}: {content!r}")

                parsed = self._parse_llm_response(content)
                if parsed is None:
                    continue

                if parsed["states"] == expected:
                    return parsed
                else:
                    log.warning(f"Попытка {attempt + 1}: {parsed['states']} != {expected}")
            except asyncio.TimeoutError:
                log.warning(f"Попытка {attempt + 1}: timeout")
            except Exception as e:
                log.warning(f"Попытка {attempt + 1}: {e}")

        log.error(f"LLM 3 раза ошиблась, fallback")
        return {
            "states": expected,
            "brightness": "dim" if self.dim_mode else "bright",
        }

    async def decide(self, fingers: int) -> dict:
        # Кэш
        if fingers == self.last_fingers:
            self.cache_hits += 1
            return {
                "states": self.bulb_states,
                "brightness": "dim" if self.dim_mode else "bright",
            }

        # Проверка стабильности
        self.history.append(fingers)
        if len(self.history) > 6:
            self.history = self.history[-6:]

        if len(self.history) < 3 or not (self.history[-1] == self.history[-2] == self.history[-3]):
            self.skipped_unstable += 1
            log.debug(f"Жест {fingers} нестабилен ({self.history[-3:]}), пропускаю LLM")
            states = self._deterministic_states(fingers)
            self.bulb_states = states
            return {
                "states": states,
                "brightness": "dim" if self.dim_mode else "bright",
            }

        # Жест стабилен — вызываем LLM
        self.last_fingers = fingers
        self.llm_calls += 1

        if self._detect_gesture(fingers):
            self.gesture_detections += 1
            if self.dim_mode:
                log.info("Режим DIM -> BRIGHT")
                self.dim_mode = False
            else:
                log.info("Режим BRIGHT -> DIM")
                self.dim_mode = True

        decision = await self.ask_llm(fingers)
        self.bulb_states = decision["states"]

        log.info(f"Пальцев: {fingers} → {self.bulb_states}")
        return decision

    def stats(self) -> str:
        return (f"LLM: {self.llm_calls}, кэш: {self.cache_hits}, "
                f"пропуски: {self.skipped_unstable}, "
                f"жестов: {self.gesture_detections}, "
                f"режим: {'DIM' if self.dim_mode else 'BRIGHT'}")


agent: SmartHomeAgent | None = None


async def connect_to_sensor():
    while True:
        try:
            log.info(f"Подключаюсь к сенсору ws://{SENSOR_HOST}:{SENSOR_PORT}...")
            async with websockets.connect(
                    f"ws://{SENSOR_HOST}:{SENSOR_PORT}",
                    ping_interval=20,
                    ping_timeout=10,
            ) as sensor_ws:
                log.info("Подключён к сенсору")

                while True:
                    data = await sensor_ws.recv()
                    payload = json.loads(data)

                    fingers = payload.get("fingers", 0)
                    hand = payload.get("hand_detected", False)
                    camera_alive = payload.get("camera_alive", False)

                    if not hand or not camera_alive:
                        if agent and agent.last_fingers != 0:
                            agent.last_fingers = -1
                        continue

                    if agent is None:
                        continue

                    decision = await agent.decide(fingers)
        except (ConnectionRefusedError, OSError) as e:
            log.warning(f"Сенсор недоступен ({e}), повтор через 2с...")
            await asyncio.sleep(2)
        except websockets.ConnectionClosed:
            log.warning("Связь с сенсором потеряна, переподключаюсь...")
            await asyncio.sleep(1)
        except Exception as e:
            log.error(f"Ошибка в connect_to_sensor: {e}")
            log.error(traceback.format_exc())
            await asyncio.sleep(2)


async def site_handler(websocket):
    peer = websocket.remote_address
    log.info(f"Сайт подключился: {peer}")
    try:
        while True:
            if agent is None:
                payload = {"states": [False] * NUM_BULBS, "brightness": "bright"}
            else:
                payload = {
                    "states": agent.bulb_states,
                    "brightness": "dim" if agent.dim_mode else "bright",
                    "stats": agent.stats()
                }
            await websocket.send(json.dumps(payload))
            await asyncio.sleep(0.2)
    except websockets.ConnectionClosed:
        log.info(f"Сайт отключился: {peer}")
    except Exception as e:
        log.error(f"Ошибка в site_handler: {e}")


async def main():
    global agent

    log.info("=" * 50)
    log.info("Запуск ИИ-агента умного дома")
    log.info("=" * 50)

    if not start_ollama_if_needed(log):
        log.error("Ollama не запущена, не могу работать")
        return

    if not ensure_model_available(OLLAMA_MODEL, log):
        log.warning(f"Модель {OLLAMA_MODEL} может быть недоступна")

    agent = SmartHomeAgent(model=OLLAMA_MODEL)

    sensor_task = asyncio.create_task(connect_to_sensor())
    log.info(f"Подключение к сенсору ws://{SENSOR_HOST}:{SENSOR_PORT}")

    log.info(f"Сервер для сайта: ws://{SITE_HOST}:{SITE_PORT}")
    log.info("Откройте site.html в браузере")

    async with websockets.serve(site_handler, SITE_HOST, SITE_PORT):
        try:
            await sensor_task
        except asyncio.CancelledError:
            log.info("Отмена задач")
        except Exception as e:
            log.error(f"Ошибка в main: {e}")
            log.error(traceback.format_exc())


if __name__ == "__main__":
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        log.info("Остановлено (Ctrl+C)")
    except Exception as e:
        log.error(f"Критическая ошибка: {e}")
        log.error(traceback.format_exc())
        input("Нажмите Enter для выхода...")
